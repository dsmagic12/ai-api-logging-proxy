# Server
PORT=8787
LOG_DIR=./logs
LOG_RAW_CONTENT=false
MAX_LOGGED_CHARS=12000

# Optional shared proxy auth. Set this and require clients to send:
# Authorization: Bearer <PROXY_SHARED_SECRET>
PROXY_SHARED_SECRET=

# Provider keys used by the proxy. Clients should not need these directly.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional upstream base URLs for private gateways, Azure-style adapters, or tests.
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default Anthropic version if the client does not send anthropic-version.
ANTHROPIC_VERSION=2023-06-01
